# ========================================
# CONFIGURATION ENVIRONNEMENT - ASTERISK MULTI-TENANT
# ========================================
# Copier ce fichier en .env et adapter les valeurs
# IMPORTANT : Ne JAMAIS committer le fichier .env
# ========================================

# ========================================
# DATABASE - PostgreSQL
# ========================================
DB_HOST=db
DB_PORT=5432
DB_NAME=asterisk
DB_USER=asterisk
DB_PASSWORD=CHANGEZ_MOI_EN_PRODUCTION  # ⚠️ CHANGER EN PRODUCTION

# ========================================
# ASTERISK MANAGER INTERFACE (AMI)
# ========================================
AMI_HOST=asterisk
AMI_PORT=5038
AMI_USER=admin
AMI_PASSWORD=CHANGEZ_MOI_EN_PRODUCTION  # ⚠️ CHANGER EN PRODUCTION

# ========================================
# API NODE.JS
# ========================================
NODE_ENV=production
PORT=3000
API_SECRET=GENERER_CLE_SECRETE_ALEATOIRE  # ⚠️ GÉNÉRER CLÉS ALÉATOIRES

# ========================================
# RESEAU - IP PUBLIQUE VPS
# ========================================
PUBLIC_IP=161.97.106.134  # ⚠️ REMPLACER PAR VOTRE IP PUBLIQUE
SIP_PORT=5060
WSS_PORT=8089
RTP_START=10000
RTP_END=10200

# ========================================
# SIP TRUNK OPERATEUR
# ========================================
TRUNK_USERNAME=62908521
TRUNK_PASSWORD=167d458f-8  # ⚠️ VÉRIFIER AVEC VOTRE OPÉRATEUR
TRUNK_SERVER=197.234.218.195
TRUNK_PORT=25060
TRUNK_DID=+22954150000

# ========================================
# SSL/TLS - CERTIFICATS
# ========================================
# Développement : certificats auto-signés (generate-ssl-certs.sh)
# Production : Let's Encrypt ou CA reconnu
SSL_CERT_PATH=/etc/asterisk/keys/fullchain.pem
SSL_KEY_PATH=/etc/asterisk/keys/privkey.pem
SSL_DOMAIN=asterisk.local  # ⚠️ REMPLACER PAR VOTRE DOMAINE

# ========================================
# LOGS & DEBUG
# ========================================
LOG_LEVEL=info  # debug, info, warn, error
ASTERISK_LOG_LEVEL=3  # 1-5 (5 = très verbeux)

# ========================================
# SÉCURITÉ
# ========================================
# Générer avec : openssl rand -base64 32
JWT_SECRET=GENERER_CLE_JWT_SECRETE  # ⚠️ GÉNÉRER EN PRODUCTION
SESSION_SECRET=GENERER_CLE_SESSION_SECRETE  # ⚠️ GÉNÉRER EN PRODUCTION

# ========================================
# CORS - AUTORISATION ORIGINES
# ========================================
CORS_ORIGIN=http://localhost:3000,https://votre-domaine.com

# ========================================
# NOTIFICATIONS (OPTIONNEL)
# ========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGEZ_MOI
EMAIL_FROM=Asterisk Platform <noreply@example.com>

# ========================================
# BACKUP (OPTIONNEL)
# ========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Tous les jours à 2h du matin
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/var/backups/asterisk

# ========================================
# PERFORMANCES
# ========================================
MAX_CONNECTIONS_DB=100
CONNECTION_POOL_SIZE=20
ODBC_MAX_CONNECTIONS=20

# ========================================
# NOTES IMPORTANTES
# ========================================
# 1. TOUJOURS changer les mots de passe par défaut
# 2. Utiliser des clés aléatoires fortes (32+ caractères)
# 3. Ne JAMAIS exposer ce fichier publiquement
# 4. Utiliser Docker secrets en production si possible
# 5. Activer HTTPS/TLS pour tous les services exposés
# ========================================
