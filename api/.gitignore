# ========================================
# ASTERISK MULTI-TENANT - GITIGNORE
# ========================================

# ========================================
# Variables d'environnement et secrets
# ========================================
.env
.env.local
.env.production
*.key
*.pem
*.crt
*.cer

# Certificats SSL
asterisk-pgsql/etc/asterisk/keys/*
!asterisk-pgsql/etc/asterisk/keys/.gitkeep

# ========================================
# Node.js
# ========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ========================================
# Logs
# ========================================
logs/
*.log
asterisk-pgsql/log/*
!asterisk-pgsql/log/.gitkeep

# Logs Asterisk
asterisk-pgsql/etc/asterisk/full
asterisk-pgsql/etc/asterisk/messages
asterisk-pgsql/etc/asterisk/error
asterisk-pgsql/etc/asterisk/debug
asterisk-pgsql/etc/asterisk/verbose

# ========================================
# Base de données
# ========================================
# Données PostgreSQL
asterisk-pgsql/.pgdata/*
!asterisk-pgsql/.pgdata/.gitkeep

# Sockets PostgreSQL
asterisk-pgsql/.pgsocket/*
!asterisk-pgsql/.pgsocket/.gitkeep

# Dumps SQL (sauf schéma)
*.dump
*.backup
backup/

# ========================================
# Docker
# ========================================
docker-compose.override.yml
.dockerignore

# ========================================
# Asterisk - Fichiers runtime
# ========================================
# Enregistrements
asterisk-pgsql/var/spool/asterisk/monitor/*
asterisk-pgsql/var/spool/asterisk/recording/*
!asterisk-pgsql/var/spool/asterisk/monitor/.gitkeep
!asterisk-pgsql/var/spool/asterisk/recording/.gitkeep

# Voicemail
asterisk-pgsql/var/spool/asterisk/voicemail/*/*

# Cache
asterisk-pgsql/var/lib/asterisk/astdb
asterisk-pgsql/var/lib/asterisk/astdb.sqlite3

# ========================================
# Système d'exploitation
# ========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ========================================
# IDE et éditeurs
# ========================================
# VSCode
.vscode/
*.code-workspace

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ========================================
# Build et dist
# ========================================
dist/
build/
out/
*.tar.gz
*.zip

# ========================================
# Tests et couverture
# ========================================
coverage/
.nyc_output/
test-results/
*.test.js.snap

# ========================================
# Temporaires
# ========================================
tmp/
temp/
*.tmp
*.temp
*.cache

# ========================================
# Sauvegardes
# ========================================
*.bak
*.backup
*.old
*_backup
*_old

# ========================================
# Documentation générée
# ========================================
docs/build/
docs/_build/
.docusaurus/

# ========================================
# React (asterisk-admin-ui)
# ========================================
asterisk-admin-ui/node_modules/
asterisk-admin-ui/build/
asterisk-admin-ui/.env.local
asterisk-admin-ui/.env.production

# ========================================
# IMPORTANT : Ne JAMAIS committer
# ========================================
# Mots de passe
passwords.txt
credentials.txt
secrets.txt

# Données sensibles
customer_data/
production_data/
*.csv
*.xlsx

# Clés API
api_keys.txt
*.api_key

# ========================================
# À GARDER dans le repo
# ========================================
# Configuration exemples
!.env.example
!docker-compose.yml

# Schémas base de données
!asterisk-pgsql/schema.sql
!asterisk-pgsql/init.sql

# Documentation
!README.md
!*.md

# Scripts
!*.sh
!verify-install.sh
!generate-ssl-certs.sh
