# ========================================
# ENVIRONMENT CONFIGURATION - ASTERISK API V2
# ========================================
# Copy this file to .env and adapt the values
# IMPORTANT: NEVER commit the .env file
# ========================================

# ========================================
# APPLICATION
# ========================================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ========================================
# DATABASE - PostgreSQL
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=asterisk
DB_USER=asterisk
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_POOL_SIZE=20

# ========================================
# ASTERISK MANAGER INTERFACE (AMI)
# ========================================
AMI_HOST=localhost
AMI_PORT=5038
AMI_USER=admin
AMI_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ========================================
# ASTERISK REST INTERFACE (ARI)
# ========================================
ARI_HOST=localhost
ARI_PORT=8088
ARI_USER=asterisk
ARI_PASSWORD=CHANGE_ME_IN_PRODUCTION
ARI_WS_URL=ws://localhost:8088/ari/events

# ========================================
# ASTERISK CONFIGURATION FILES
# ========================================
# Path to Asterisk configuration directory
# This is used by RegistrationsService to manage pjsip_wizard.conf
ASTERISK_CONFIG_PATH=/etc/asterisk

# Timeout for Asterisk reload operations (milliseconds)
ASTERISK_RELOAD_TIMEOUT=5000

# ========================================
# REDIS CACHE
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache TTL (seconds)
CACHE_TTL_STATS=30
CACHE_TTL_ENDPOINTS=60
CACHE_TTL_QUEUES=30

# ========================================
# JWT AUTHENTICATION
# ========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=GENERATE_RANDOM_SECRET_KEY
JWT_EXPIRES_IN=1d

# ========================================
# SECURITY
# ========================================
# CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info  # debug, info, warn, error
LOG_DIR=logs

# ========================================
# SWAGGER DOCUMENTATION
# ========================================
SWAGGER_ENABLED=true
SWAGGER_TITLE=Asterisk VoIP Call Center API
SWAGGER_DESCRIPTION=Multi-tenant VoIP Call Center Management API
SWAGGER_VERSION=2.0
SWAGGER_PATH=api/docs

# ========================================
# NETWORK - PUBLIC IP & SIP DOMAIN
# ========================================
PUBLIC_IP=161.97.106.134
SIP_DOMAIN=pishon.kabou.bj
SIP_PORT=5060
WSS_PORT=8089
SIP_REALM=pishon.kabou.bj
RTP_START=10000
RTP_END=10200
